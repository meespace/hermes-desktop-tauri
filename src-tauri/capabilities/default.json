{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:webview:allow-internal-toggle-devtools",
    "core:webview:allow-set-webview-zoom",
    "websocket:default"
  ]
}
